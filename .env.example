# YouTube Shorts Bot — Environment Variables
# Copy this file to .env and fill in your credentials.

# --- Gemini AI (quote generation & captions) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- YouTube Data API v3 (video uploads) ---
# OAuth 2.0 credentials — create at https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret
# Refresh token obtained after running the OAuth consent flow once
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
